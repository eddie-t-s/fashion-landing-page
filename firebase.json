{
  "functions": [
    {
      "source": "functions"
    }
  ],
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "firebase-debug.log"
    ],
    "rewrites": [
      {
        "source": "/api/submitOrder",
        "function": "submitOrder"
      }
    ]
  }
}
